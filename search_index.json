,"二次开发","二次开发文档","交流","任务完成时想做的事","使用","使用文档","信息提示","内容","动画进来时的方向","图片，","安装下载","完成开发","就是这么简单","当我想要一个提示一个消息的时候，简单的系统提示太简陋，有名的如","快速使用","执行","持续时间","持续时间，默认","提问","提问：https://github.com/menghuancode/tip/issu","是否是","是否显示多个，默认","是否显示遮罩","是否显示遮罩，默认","显示","有显的太臃肿，于是自己写一个。","标题","模拟任务执行完毕，","消息提示","目录的源码","简介","简单直接、小巧的的信息提示","编辑","群：496407683","自定义配置","进行开发","配置","项目介绍","默认","默认右边","默认配置"],"pipeline":["stopWordFilter","stemmer"]},"store":{"./":{"url":"./","title":"项目介绍","keywords":"","body":"tip 信息提示\n简单直接、小巧的的信息提示\n简介\n当我想要一个提示一个消息的时候，简单的系统提示太简陋，有名的如 layer 有显的太臃肿，于是自己写一个。\n安装下载\n\n下载地址 https://github.com/menghuanCode/tip/releases\nnpm i zh-tip\nCDN http://unpkg.com/zh-tip/example/js/layout.js\n\n快速使用\n// 消息提示\ntip('我是消息提示') \n\n// loading\nvar loading = tip('')\n// 模拟任务执行完毕，\nsetTimeout(function () {\n    loading.close()\n}, 3000)\n\n\n使用文档\n二次开发文档\n\n交流 & 提问\n\n提问：https://github.com/menghuanCode/tip/issues\nQQ 群：496407683\n\n"},"doc/use/":{"url":"doc/use/","title":"使用文档","keywords":"","body":"使用文档\n使用\n消息提示\ntip('我是消息提示')   // 就是这么简单\n\nloading\nvar loading = tip('')\n// 模拟任务执行完毕，\nsetTimeout(function () {\n    loading.close()\n}, 3000)\n\n自定义配置\ntip({\n    content: '你好啊',         // 内容\n    duration: 3000              // 持续时间\n    direction： 'center'      // 动画进来时的方向\n    shade:  true              // 是否显示遮罩\n})\n\n// 下面会介绍有哪些默认配置\n\n配置\n默认配置\n{\n    title: '',                  // 标题\n    content: '',                // 内容       \n    duration: 1000,             // 持续时间，默认 1000 ms\n    direction: 'center',        // 动画进来时的方向 ['top', 'bottom', 'left', 'right'] 默认右边\n    shade: true,                                // 是否显示遮罩，默认 true\n    multile: false,                        // 是否显示多个，默认 false（第二个显示出来的时候，第一个会消失）\n    isImage: false,                          // 是否是 图片， 默认 false，当然假如你传的是图片，它会自动改成 ture，当 loading 显示\n    onComplete: function () {}    // 任务完成时想做的事\n}\n\n"},"doc/dev/":{"url":"doc/dev/","title":"二次开发","keywords":"","body":"二次开发\n\n下载 git clone https://github.com/menghuanCode/tip.git\n编辑 src 目录的源码\n执行 npm run dev 进行开发\n执行 npm run build 完成开发\n\n"}}}